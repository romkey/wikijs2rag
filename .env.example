# ── Wiki.js connection ─────────────────────────────────────────────────────────
# Base URL of your Wiki.js instance (no trailing slash).
WIKI_URL=https://wiki.example.com

# Optional: Wiki.js API key.
# Create one at /a/api-keys in the admin panel (read-only scope is enough).
# Leave empty if your wiki allows unauthenticated GraphQL access.
WIKI_API_KEY=

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# These default to the values shown when running under docker compose.
# Override only if you point to an external Qdrant instance.
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# Name of the Qdrant collection to write to.
# Use different collection names to keep multiple wikis separate.
QDRANT_COLLECTION=wiki

# Host ports exposed by docker compose (optional overrides).
# QDRANT_REST_PORT=6333
# QDRANT_GRPC_PORT=6334

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Backend: "local"  (fastembed / ONNX, baked into the Docker image)
#          "ollama" (Ollama HTTP API, use your own local LLM server)
#          "openai" (OpenAI Embeddings API, requires OPENAI_API_KEY)
EMBEDDING_BACKEND=local

# ── local backend ──
# fastembed model name.  Must be from fastembed's supported list; run:
#   python -c "from fastembed import TextEmbedding; print(*TextEmbedding.list_supported_models(), sep='\n')"
# Popular choices:
#   BAAI/bge-small-en-v1.5                              – 384-dim, fast  (default)
#   BAAI/bge-base-en-v1.5                               – 768-dim, higher quality
#   sentence-transformers/all-MiniLM-L6-v2              – 384-dim
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── ollama backend ──
# EMBEDDING_BACKEND=ollama
# EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_URL=http://host.docker.internal:11434
#
# Popular Ollama embedding models (pull with `ollama pull <name>`):
#   nomic-embed-text     – 768-dim, good quality  (default)
#   all-minilm           – 384-dim, fast
#   mxbai-embed-large    – 1024-dim, highest quality
#   snowflake-arctic-embed – 1024-dim

# ── openai backend ──
# EMBEDDING_BACKEND=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# ── Chunking ───────────────────────────────────────────────────────────────────
# Maximum words per chunk.  256 keeps chunks well within the embedding model's
# token window (BGE-small has a 512-token limit) and gives the chatbot focused,
# precise context.
CHUNK_SIZE=256

# Words of overlap between consecutive chunks.
CHUNK_OVERLAP=50

# Parent chunk ratio: every N consecutive chunks share the same parent_chunk_index.
# Used for small-to-big retrieval – search on small chunks, then pull the parent
# group for broader context.
PARENT_CHUNK_RATIO=4

# ── Ingestion behaviour ───────────────────────────────────────────────────────
# Set to true to re-ingest all pages even if updatedAt hasn't changed.
# Normally, unchanged pages are skipped for faster incremental runs.
FORCE_REINGEST=false

# ── Performance ────────────────────────────────────────────────────────────────
# Number of chunks encoded in a single embedding call.
EMBEDDING_BATCH_SIZE=32

# Seconds to wait between page fetches (avoid hammering the wiki).
PAGE_DELAY_SECONDS=0.1

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
